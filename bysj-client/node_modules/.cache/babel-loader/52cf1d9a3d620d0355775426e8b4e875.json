le,\r\n                ziduan:ziduan,\r\n                id\r\n            }).then(res=>{\r\n                if(res.code == api.code.OK)\r\n                {\r\n                    MessageBox.alert('收藏成功');\r\n                    resolve();\r\n                }else{\r\n                    MessageBox.alert(res.msg);\r\n                    reject(res.msg);\r\n                }\r\n            }).catch(err=>{\r\n                MessageBox.alert(err.message);\r\n                reject(err.message);\r\n            });\r\n        });\r\n    }\r\n\r\n    Vue.mixin({\r\n        methods:{\r\n            $print(){\r\n                var print = this.$refs.print;\r\n\r\n                var app = document.querySelector(\"#app\");\r\n                // 根节点\r\n                var html = print.cloneNode(true);\r\n                var div = document.createElement('div');\r\n                div.appendChild(html);\r\n                document.body.append(div);\r\n                app.style.display = 'none';\r\n                window.print();\r\n                app.style.display = 'block';\r\n                document.body.removeChild(div);\r\n            }\r\n        }\r\n    });\r\n\r\n    Vue.prototype.$substr = function (str , len , append='...'){\r\n        var content = str.replace(/<[^>]+>/g, \"\").replace(/&nbsp;/i,' ');\r\n        if(content.length < len){\r\n            return content;\r\n        }\r\n        return content.substr(0, len)+append;\r\n    }\r\n\r\n    Vue.prototype.$formatImageSrc = formatImageSrc;\r\n\r\n    Vue.prototype.$goto = function (url , replace = false) {\r\n\r\n        if(isString(url) && (url == '#' || url.indexOf('javascript:')!=-1))return;\r\n\r\n        if(isString(url) && url.match(/^https?:\\/\\//ig) ){\r\n            if(this.replace){\r\n                location.replace( url );\r\n            }else{\r\n                location.href = url;\r\n            }\r\n            return;\r\n        }\r\n\r\n        if(replace){\r\n            router.replace(url);\r\n        }else{\r\n            router.push(url);\r\n        }\r\n    }\r\n\r\n    Vue.mixin({\r\n        computed:{\r\n            $session(){\r\n                return store.state.user.session\r\n            }\r\n        }\r\n    });\r\n\r\n    Vue.use(Viewer)\r\n    Viewer.setDefaults({\r\n        Options: { 'inline': true, 'button': true, 'navbar': true, 'title': true, 'toolbar': true, 'tooltip': true, 'movable': true, 'zoomable': true, 'rotatable': true, 'scalable': true, 'transition': true, 'fullscreen': true, 'keyboard': true, 'url': 'data-source' }\r\n    })\r\n\r\n\r\n}\r\n\r\nexport default install\r\n\r\n\r\n"],"mappings":";AAAA,OAAOA,IAAI,MAAM,mBAAmB;AACpC,OAAOC,GAAG,MAAM,OAAO;AACvB,SAAQC,UAAU,QAAO,YAAY;AACrC,SAAQC,cAAc,QAAO,eAAe;AAC5C,OAAOC,MAAM,MAAM,UAAU;AAC7B,OAAO,0BAA0B;AACjC,OAAOC,MAAM,MAAM,UAAU;AAC7B,OAAOC,KAAK,MAAM,SAAS;AAC3B,SAAQC,QAAQ,QAAO,gBAAgB;AAEvC,SAASC,OAAOA,CAACC,GAAG,EAAE;EAClBA,GAAG,CAACC,SAAS,CAACC,QAAQ,GAAG,UAAUC,MAAM,EAAGC,MAAM,EAAGC,EAAE,EAAE;IACrD,OAAO,IAAIC,OAAO,CAAC,CAACC,OAAO,EAAEC,MAAM,KAAK;MACpCjB,IAAI,CAACkB,IAAI,CAACjB,GAAG,CAACkB,OAAO,EAAG;QACpBC,IAAI,EAACR,MAAM;QACXC,MAAM,EAACA,MAAM;QACbC;MACJ,CAAC,CAAC,CAACO,IAAI,CAACC,GAAG,IAAE;QACT,IAAGA,GAAG,CAACC,IAAI,IAAItB,GAAG,CAACsB,IAAI,CAACC,EAAE,EAC1B;UACItB,UAAU,CAACuB,KAAK,CAAC,MAAM,CAAC;UACxBT,OAAO,CAAC,CAAC;QACb,CAAC,MAAI;UACDd,UAAU,CAACuB,KAAK,CAACH,GAAG,CAACI,GAAG,CAAC;UACzBT,MAAM,CAACK,GAAG,CAACI,GAAG,CAAC;QACnB;MACJ,CAAC,CAAC,CAACC,KAAK,CAACC,GAAG,IAAE;QACV1B,UAAU,CAACuB,KAAK,CAACG,GAAG,CAACC,OAAO,CAAC;QAC7BZ,MAAM,CAACW,GAAG,CAACC,OAAO,CAAC;MACvB,CAAC,CAAC;IACN,CAAC,CAAC;EACN,CAAC;EAEDpB,GAAG,CAACqB,KAAK,CAAC;IACNC,OAAO,EAAC;MACJC,MAAMA,CAAA,EAAE;QACJ,IAAIC,KAAK,GAAG,IAAI,CAACC,KAAK,CAACD,KAAK;QAE5B,IAAIE,GAAG,GAAGC,QAAQ,CAACC,aAAa,CAAC,MAAM,CAAC;QACxC;QACA,IAAIC,IAAI,GAAGL,KAAK,CAACM,SAAS,CAAC,IAAI,CAAC;QAChC,IAAIC,GAAG,GAAGJ,QAAQ,CAACK,aAAa,CAAC,KAAK,CAAC;QACvCD,GAAG,CAACE,WAAW,CAACJ,IAAI,CAAC;QACrBF,QAAQ,CAACO,IAAI,CAACC,MAAM,CAACJ,GAAG,CAAC;QACzBL,GAAG,CAACU